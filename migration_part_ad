  )
  INTO score_dist
  FROM public_quiz_runs
  WHERE question_set_id = p_question_set_id AND status = 'completed';

  -- Daily trend (last 30 days)
  SELECT jsonb_agg(
    jsonb_build_object(
      'date', day::date,
