-- Helper function to generate slug from text
CREATE OR REPLACE FUNCTION generate_slug(input_text text, subject_prefix text)
RETURNS text AS $$
BEGIN
  RETURN lower(
    regexp_replace(
      regexp_replace(subject_prefix || '-' || input_text, '[^a-zA-Z0-9\s-]', '', 'g'),
      '\s+',
      '-',
      'g'
    )
  );
END;
$$ LANGUAGE plpgsql;

